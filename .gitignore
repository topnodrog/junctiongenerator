# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (root and workspaces)
/node_modules
packages/*/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
packages/*/coverage

# next.js
/.next/
packages/web/.next/
/out/
packages/web/out/

# jgc-node build output
packages/jgc-node/dist/
packages/jgc-node/rust/pkg/

# rust build artifacts (Cargo target dirs — multi-GB, never commit)
target/
packages/jgc-node/rust/target/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
